# Copy to .env and fill in real secrets. .env is gitignored.
# Both secrets are server-only — never expose them to the client (no NEXT_PUBLIC_*).
INFLUXDB_URL=https://your-influxdb-host:8086
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=your-bucket
INFLUXDB_TOKEN=__HIER_READ_TOKEN_EINSETZEN__

# Anthropic (Claude) — used server-side by /api/ask for NL → QuerySpec (tool use).
ANTHROPIC_API_KEY=__HIER_ANTHROPIC_KEY_EINSETZEN__
