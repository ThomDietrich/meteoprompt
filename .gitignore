# ──────────────────────────────────────────────────────────────
# Runtime server-side data (pinned cards, failed-query log) — spec-05
# ──────────────────────────────────────────────────────────────
/data/

# ──────────────────────────────────────────────────────────────
# Dependencies
# ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ──────────────────────────────────────────────────────────────
# Next.js / build output
# ──────────────────────────────────────────────────────────────
/.next/
/out/
/build
/dist
.vercel
.turbo

# ──────────────────────────────────────────────────────────────
# TypeScript
# ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ──────────────────────────────────────────────────────────────
# Testing / coverage
# ──────────────────────────────────────────────────────────────
/coverage

# ──────────────────────────────────────────────────────────────
# Environment & secrets  (keep .env.example tracked)
# ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────────────────────────────────────────
# Logs & debug
# ──────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ──────────────────────────────────────────────────────────────
# Editors / IDE
# ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp

# ──────────────────────────────────────────────────────────────
# OS files
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ──────────────────────────────────────────────────────────────
# Docker — your own compose is yours (copy from docker-compose.dist.yaml).
# Only docker-compose.dist.yaml is tracked.
# ──────────────────────────────────────────────────────────────
docker-compose.yaml
docker-compose.yml
docker-compose.override.yml
docker-compose.override.yaml

# ──────────────────────────────────────────────────────────────
# Tooling state
# ──────────────────────────────────────────────────────────────
.omc/
.claude/settings.local.json

# ──────────────────────────────────────────────────────────────
# Playwright (verification scratch artifacts)
# ──────────────────────────────────────────────────────────────
.playwright-mcp/
